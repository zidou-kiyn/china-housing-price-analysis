# 复制为 .env.prod 并替换敏感值后使用：
#   cp .env.prod.example .env.prod
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d

# 数据库 / Redis（compose 内网服务名寻址）
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/housing_price
DATABASE_URL_SYNC=postgresql://postgres:postgres@postgres:5432/housing_price
REDIS_URL=redis://redis:6379/0
POSTGRES_PASSWORD=postgres

# 安全（生产必须替换为随机强密钥）
JWT_SECRET_KEY=change-me-to-a-long-random-secret

# 运行环境
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO
