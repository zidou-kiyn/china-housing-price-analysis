# 复制为 .env.prod 并替换敏感值后使用：
#   cp .env.prod.example .env.prod
#   docker compose -f docker-compose.yml --env-file .env.prod up -d --build

# 数据库
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/housing_price
DATABASE_URL_SYNC=postgresql://postgres:postgres@postgres:5432/housing_price
POSTGRES_PASSWORD=postgres

# Redis
REDIS_URL=redis://redis:6379/0

# 安全（生产必须替换为随机强密钥）
JWT_SECRET_KEY=MUST-CHANGE-TO-RANDOM-SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# 采集
CRAWL_REQUEST_DELAY_MIN=1.0
CRAWL_REQUEST_DELAY_MAX=3.0
CRAWL_MAX_RETRIES=3

# 应用
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO
# ML_MODEL_DIR=models
# GEO_DIR=
