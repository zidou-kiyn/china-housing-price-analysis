# 数据库
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/housing_price
DATABASE_URL_SYNC=postgresql://postgres:postgres@postgres:5432/housing_price
POSTGRES_PASSWORD=postgres

# Redis
REDIS_URL=redis://redis:6379/0

# 安全
JWT_SECRET_KEY=dev-only-insecure-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# 采集
CRAWL_REQUEST_DELAY_MIN=0.5
CRAWL_REQUEST_DELAY_MAX=1.5
CRAWL_MAX_RETRIES=3
CRAWL_CONCURRENCY=3

# 应用
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
# ML_MODEL_DIR=models
# GEO_DIR=
